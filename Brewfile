# Homebrew dependencies for this dotfiles setup.
# Install with `./install-deps.sh` (runs `brew bundle`). Idempotent.

tap "espanso/espanso"

# Shell + prompt
brew "fish"
brew "starship"
brew "zsh-syntax-highlighting"
brew "zsh-autosuggestions"

# Tooling
brew "fnm"      # Node version manager
brew "direnv"   # per-directory env

# Casks
cask "ghostty"                        # terminal emulator
cask "espanso"                        # text expander
cask "font-droid-sans-mono-nerd-font" # terminal font
