# Font (Nerd Font required for starship's branch / language glyphs)
# Install once:
#   brew install --cask font-jetbrains-mono-nerd-font
font-family = JetBrainsMono Nerd Font
font-size = 20

# Run fish explicitly so this works even before/without chsh.
command = /opt/homebrew/bin/fish --login

# Window padding
window-padding-x = 6
window-padding-y = 6

# Theme — closest built-in match to the prior iTerm2 default-with-grey-bg setup.
theme = iTerm2 Default
background = 404040
foreground = bbbbbb

# Translucent background with blur (matches the prior iTerm2 setup).
# Comment these two lines for a fully opaque window.
background-opacity = 0.88
background-blur = 21
